{
  "extends": "@gravity-ui/tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "build/esm",
    "module": "esnext",
    "jsx": "react",
    "baseUrl": ".",
    "importHelpers": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test-utils/**/*.ts",
    "test-utils/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "vitest.shims.d.ts",
    "vitest.config.ts"
  ]
}
